# ─── Required in production ──────────────────────
NODE_ENV=production
SESSION_SECRET=generate-a-long-random-string-here-32-chars-minimum
CORS_ORIGIN=https://aztechcoworks.in
PORT=3001

# ─── Razorpay (payment gateway) ─────────────────
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Resend (transactional email) ────────────────
# Get key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Aztech Co-Works <noreply@aztechcoworks.in>
SITE_URL=https://aztechcoworks.in

# ─── WhatsApp Business API ──────────────────────
# Configure after BSP setup (Interakt/Wati/Gupshup)
WHATSAPP_API_KEY=
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_ID=
