# Aztech Co-Works PHP Backend — Environment Variables
# Copy this to .env and fill in real values for production.

# Frontend URL (for email links & CORS)
SITE_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Resend (transactional email)
RESEND_API_KEY=
EMAIL_FROM=Aztech Co-Works <noreply@aztechcoworks.in>

# Razorpay (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_API_KEY=
WHATSAPP_API_URL=
WHATSAPP_PHONE_ID=
